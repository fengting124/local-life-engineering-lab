# ================================================================
# LocalLife Copilot Agent Service — 环境变量模板
# 复制此文件为 .env，填写真实值后启动服务
# ================================================================

# ===== LLM 配置（选择一个 Provider）=====
# 选项 A：Anthropic Claude（工具调用最稳定，推荐）
LLM_PROVIDER=anthropic
LLM_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_MODEL=claude-sonnet-4-6

# 选项 B：DeepSeek（性价比最高，¥2/百万token，国内访问友好）
# LLM_PROVIDER=deepseek
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LLM_MODEL=deepseek-chat
# LLM_BASE_URL=  # 留空用默认 https://api.deepseek.com/v1

# 选项 C：通义千问 Qwen（国内可用，阿里云账号）
# LLM_PROVIDER=qwen
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LLM_MODEL=qwen-max
# LLM_BASE_URL=  # 留空用默认 https://dashscope.aliyuncs.com/compatible-mode/v1

# 选项 D：本地 Ollama（完全离线，需要先 ollama pull qwen2.5:7b）
# LLM_PROVIDER=local
# LLM_API_KEY=ollama
# LLM_MODEL=qwen2.5:7b
# LLM_BASE_URL=http://localhost:11434/v1

# ===== Java MCP Server 地址 =====
# local-life-copilot 服务地址（默认本地 8081）
MCP_SERVER_URL=http://localhost:8081

# ===== 数据库 =====
# 与 LocalLife Server 共享同一个 MySQL（local_life 数据库）
DB_URL=mysql+aiomysql://root:123456@localhost:3306/local_life

# ===== Redis =====
# 使用 DB 2（与 LocalLife Server 的 DB 0 / MCP Server 的 DB 1 隔离）
REDIS_URL=redis://localhost:6379/2

# ===== Milvus（RAG 向量检索）=====
MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION=locallife_knowledge

# ===== Agent 参数 =====
AGENT_MAX_STEPS=15
SESSION_TOKEN_BUDGET=50000
REFLECTION_INTERVAL=5

# ===== 服务端口 =====
APP_PORT=8000
DEBUG=true
