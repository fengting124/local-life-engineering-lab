# ================================================================
# LocalLife Copilot Agent Service — 环境变量模板
# 复制此文件为 .env，填写真实值后启动服务
# ================================================================

# ===== LLM 配置（选择一个 Provider，默认 DeepSeek）=====
# 日常开发调试用 DeepSeek（¥2/百万 token），面试演示可切 Claude
#
# 不管选哪个 provider，统一填 LLM_API_KEY / LLM_MODEL / LLM_BASE_URL 三个通用字段——
# _create_llm() 工厂函数（agent/nodes.py）只认这三个 + LLM_PROVIDER，
# 不会读 DEEPSEEK_API_KEY / QWEN_MODEL 之类的专属变量名。

# 选项 A：DeepSeek（性价比最高，国内访问友好，推荐日常开发）
LLM_PROVIDER=deepseek
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_MODEL=deepseek-v4-flash
# LLM_BASE_URL 留空则自动使用 https://api.deepseek.com/v1

# 选项 B：Anthropic Claude（工具调用最稳定，推荐面试演示）
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   ← 兼容字段名，LLM_API_KEY 留空时回退到它
# LLM_MODEL=claude-sonnet-4-6

# 选项 C：通义千问 Qwen（国内可用，阿里云账号）
# LLM_PROVIDER=qwen
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LLM_MODEL=qwen-max
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 选项 D：本地 Ollama（完全离线，需要先 ollama pull qwen2.5:7b）
# LLM_PROVIDER=local
# LLM_API_KEY=ollama
# LLM_MODEL=qwen2.5:7b
# LLM_BASE_URL=http://localhost:11434/v1

# ===== Java MCP Server 地址 =====
# local-life-copilot 服务地址（默认本地 8081）
MCP_SERVER_URL=http://localhost:8081

# ===== 数据库 =====
# 与 LocalLife Server 共享同一个 MySQL（local_life 数据库）
DB_URL=mysql+aiomysql://root:123456@localhost:3306/local_life

# ===== Redis =====
# 使用 DB 2（与 LocalLife Server 的 DB 0 / MCP Server 的 DB 1 隔离）
REDIS_URL=redis://localhost:6379/2

# ===== RAG 本地模型服务（通过 Docker Compose rag profile 启动）=====
EMBEDDING_SERVICE_URL=http://localhost:8100
RERANKER_SERVICE_URL=http://localhost:8101

# ===== Milvus（RAG 向量检索）=====
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=local_life_kb

# Embedding 模型（必须与 embedding-service 中的 EMBEDDING_MODEL_NAME 一致）
EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-base
EMBEDDING_DIMENSION=768

# RAG 检索参数
RAG_TOP_K_RECALL=20
RAG_TOP_K_RERANK=5
RAG_MIN_SCORE=0.3
RAG_TIMEOUT_SECONDS=10

# ===== Agent 参数 =====
AGENT_MAX_STEPS=15
SESSION_TOKEN_BUDGET=50000
REFLECTION_INTERVAL=5

# ===== 服务端口 =====
APP_PORT=8000
DEBUG=true
