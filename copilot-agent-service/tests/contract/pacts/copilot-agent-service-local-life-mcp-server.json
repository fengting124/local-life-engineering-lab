{
  "consumer": {
    "name": "copilot-agent-service"
  },
  "interactions": [
    {
      "description": "a tools/call for query_order that returns not_found",
      "request": {
        "body": {
          "id": null,
          "jsonrpc": "2.0",
          "method": "tools/call",
          "params": {
            "arguments": {
              "order_no": "NOTFOUND"
            },
            "name": "query_order"
          }
        },
        "generators": {
          "body": {
            "$.id": {
              "type": "Uuid"
            }
          }
        },
        "headers": {
          "Content-Type": "application/json",
          "X-User-Id": "1",
          "X-User-Role": "merchant"
        },
        "matchingRules": {
          "body": {
            "$.id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^([0-9a-f]{8}(-[0-9a-f]{4}){3}-[0-9a-f]{12}|[0-9A-F]{8}(-[0-9A-F]{4}){3}-[0-9A-F]{12})$"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/mcp"
      },
      "response": {
        "body": {
          "error": {
            "data": {
              "detail": "订单不存在: NOTFOUND",
              "hint": "请确认订单号",
              "reason": "not_found"
            },
            "message": "tool failed"
          },
          "id": null,
          "jsonrpc": "2.0"
        },
        "generators": {
          "body": {
            "$.id": {
              "type": "Uuid"
            }
          }
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^([0-9a-f]{8}(-[0-9a-f]{4}){3}-[0-9a-f]{12}|[0-9A-F]{8}(-[0-9A-F]{4}){3}-[0-9A-F]{12})$"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a tools/call for query_order that succeeds",
      "request": {
        "body": {
          "id": null,
          "jsonrpc": "2.0",
          "method": "tools/call",
          "params": {
            "arguments": {
              "order_no": "ORD1"
            },
            "name": "query_order"
          }
        },
        "generators": {
          "body": {
            "$.id": {
              "type": "Uuid"
            }
          }
        },
        "headers": {
          "Content-Type": "application/json",
          "X-User-Id": "1",
          "X-User-Role": "merchant"
        },
        "matchingRules": {
          "body": {
            "$.id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^([0-9a-f]{8}(-[0-9a-f]{4}){3}-[0-9a-f]{12}|[0-9A-F]{8}(-[0-9A-F]{4}){3}-[0-9A-F]{12})$"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/mcp"
      },
      "response": {
        "body": {
          "id": null,
          "jsonrpc": "2.0",
          "result": {
            "content": [
              {
                "text": "订单状态：已支付",
                "type": "text"
              }
            ]
          }
        },
        "generators": {
          "body": {
            "$.id": {
              "type": "Uuid"
            }
          }
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^([0-9a-f]{8}(-[0-9a-f]{4}){3}-[0-9a-f]{12}|[0-9A-F]{8}(-[0-9A-F]{4}){3}-[0-9A-F]{12})$"
                }
              ]
            }
          }
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pactRust": {
      "ffi": "0.5.4",
      "models": "1.3.11"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "local-life-mcp-server"
  }
}