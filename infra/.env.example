# ================================================================
# LocalLife × LocalLife Copilot — Docker Compose 环境变量模板
# 复制此文件为 .env 后填写真实值
# ================================================================

# ===== 数据库 =====
MYSQL_ROOT_PASSWORD=123456
MYSQL_DATABASE=local_life
MYSQL_PORT=3306

# ===== Redis =====
REDIS_PORT=6379

# ===== 应用服务端口 =====
SERVER_PORT=8080          # LocalLife Server
COPILOT_PORT=8081         # MCP Server
AGENT_PORT=8000           # Agent Service

# ===== LLM =====
# 必填：Anthropic API Key（获取地址：https://console.anthropic.com/）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxx
LLM_MODEL=claude-sonnet-4-6

# ===== 搜索 =====
ELASTIC_PORT=9200

# ===== 消息队列 =====
ROCKETMQ_NAMESRV_PORT=9876
ROCKETMQ_BROKER_PORT=10911

# ===== 可观测性 =====
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_PASSWORD=admin
ZIPKIN_PORT=9411

# ===== RAG =====
MILVUS_PORT=19530
ATTU_PORT=3001

# ===== 内部 API 密钥（LocalLife Server ↔ Copilot）=====
INTERNAL_API_KEY=local-life-internal-secret

# ===== RAG 本地模型服务 =====
EMBEDDING_PORT=8100
RERANKER_PORT=8101

# Embedding 模型（默认 768 维多语言 e5，切换时同步改 MILVUS_COLLECTION）
EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-base
EMBEDDING_DIMENSION=768
EMBEDDING_DEVICE=auto          # auto | cuda | cpu
EMBEDDING_NORMALIZE=true
MAX_BATCH_SIZE=64
MAX_TEXT_LENGTH=2048

# Reranker 模型（默认中文 bge-reranker-base）
RERANKER_MODEL_NAME=BAAI/bge-reranker-base
RERANKER_DEVICE=auto           # auto | cuda | cpu
MAX_DOCUMENTS=50
MAX_QUERY_LENGTH=512
MAX_DOCUMENT_LENGTH=2048

# ===== WSL 代理（WSL mirrored networking，需与 Windows 代理端口一致）=====
# 若无代理，留空即可
HTTP_PROXY=http://127.0.0.1:9674
HTTPS_PROXY=http://127.0.0.1:9674
ALL_PROXY=http://127.0.0.1:9674
